import random
import string
print("---құпиясөз генераторы---")
uzyndyk=int(input("құпиясөз ұзақтығы(8 немесе 12,16): "))
aripter=string.ascii_letters
sandar=string.digits
tanbalar=string.punctuation
barlyk_tanbalar=aripter+sandar+tanbalar
dayun_tizim=random.choices(barlyk_tanbalar,k=uzyndyk)
dayyn="".join(dayun_tizim)
print("сенің құпиясөзің:",dayyn)

